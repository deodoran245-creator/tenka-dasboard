# ==========================================
# ALIP BOT DASHBOARD CONFIGURATION
# ==========================================

# Dashboard Access Credentials
# Ganti dengan email dan username yang kamu inginkan untuk login dashboard
ADMIN_EMAIL=azizahzjjah@gmail.com
ADMIN_USERNAME=King-paiz
ADMIN_PASSWORD=Paiz-king

# Bot API Connection
# URL bot utama kamu yang sedang running (biasanya localhost:3000 atau domain hosting)
BOT_API_URL=http://localhost:3000
# API key bot (lihat di settings.js bot utama global.botSecretKey = "alip-ai")
BOT_API_KEY=alip-ai

# Server Configuration
# Port untuk dashboard (jangan konflik dengan bot utama)
PORT=3001
NODE_ENV=production

# Security Settings
JWT_SECRET=alip-dashboard-secret-2025
SESSION_TIMEOUT=3600000

# Optional: External Services
# CLOUDFLARE_ZONE_ID=your-zone-id
# CLOUDFLARE_API_TOKEN=your-api-token
# CLOUDFLARE_DOMAIN=yourdomain.com

# ==========================================
# CARA MENDAPATKAN NILAI YANG BENAR:
# ==========================================
#
# 1. ADMIN_EMAIL: Email apa saja yang valid untuk login dashboard
#    Contoh: dashboard@alipbot.com atau admin@gmail.com
#
# 2. ADMIN_USERNAME: Username apa saja untuk login dashboard
#    Contoh: admin, paiz, kingpaiz
#
# 3. ADMIN_PASSWORD: Password apa saja untuk login dashboard
#    Contoh: alipbot2025, kingpaiz123, admin123
#
# 4. BOT_API_URL: Jika bot running di localhost, gunakan http://localhost:3000
#                 Jika di hosting, gunakan URL hosting bot kamu
#                 Contoh: https://bot-alip.herokuapp.com atau http://localhost:3000
#
# 5. BOT_API_KEY: Lihat di file settings.js bot utama:
#                 global.botSecretKey = "alip-ai" (default value)
#
# 6. PORT: 3001 (jangan sama dengan port bot utama)
#
# ==========================================
# CONTOH KONFIGURASI LENGKAP:
# ==========================================
# ADMIN_EMAIL=dashboard@alipbot.com
# ADMIN_USERNAME=paiz
# ADMIN_PASSWORD=kingpaiz123
# BOT_API_URL=https://bot-alip.herokuapp.com
# BOT_API_KEY=alip-ai
# PORT=3001